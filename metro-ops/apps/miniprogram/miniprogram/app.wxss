.page {
  min-height: 100vh;
  background: #f8fafc;
  color: #0f172a;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.subtle {
  color: #64748b;
  font-size: 24rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pill-primary {
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
}

.pill-green {
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
}

.pill-amber {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.pill-gray {
  background: #e2e8f0;
  color: #475569;
}

.button-row {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 14rpx;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  line-height: 1.2;
  border: 0;
}

.btn-primary {
  background: #2563eb;
  color: #ffffff;
}

.btn-secondary {
  background: #0f172a;
  color: #ffffff;
}

.btn-muted {
  background: #e2e8f0;
  color: #0f172a;
}

.btn:disabled {
  opacity: 0.5;
}
