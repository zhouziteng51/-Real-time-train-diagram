<view class="page">
  <view class="card">
    <view class="row">
      <view class="title">实时车次</view>
      <view class="pill pill-primary">{{connectionLabel}}</view>
    </view>
  </view>

  <view class="card">
    <block wx:for="{{trips}}" wx:key="id">
      <navigator url="/pages/trip/index?id={{item.id}}" class="trip-row">
        <view class="stack">
          <view class="font-bold">{{item.trainNo}} · {{item.routeId}}</view>
          <view class="subtle">{{item.originStationId}} → {{item.terminalStationId}}</view>
        </view>
        <view class="pill {{item.statusClass}}">{{item.statusLabel}}</view>
      </navigator>
    </block>
    <view wx:if="{{trips.length === 0}}" class="subtle">暂无任务</view>
  </view>
</view>
