.trip-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1px solid #e2e8f0;
  gap: 20rpx;
}

.trip-row:first-of-type {
  border-top: 0;
}

.font-bold {
  font-size: 30rpx;
  font-weight: 600;
}

.trip-row .stack {
  min-width: 0;
  flex: 1;
}

.trip-row .stack .subtle,
.trip-row .stack .font-bold {
  word-break: break-word;
}

.task-card {
  padding-bottom: 20rpx;
}

.task-header {
  align-items: flex-start;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.location-panel {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.location-text {
  margin: 8rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  word-break: break-word;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.info-cell {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 0;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.info-cell.wide {
  flex-basis: 100%;
}

.info-cell view:last-child {
  margin-top: 4rpx;
  word-break: break-word;
}

.align-right {
  align-items: flex-end;
  text-align: right;
}

.task-card .title,
.task-card .subtle,
.location-panel .subtle {
  word-break: break-word;
}

.meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-item {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 0;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.meta-item.wide {
  flex-basis: 100%;
}

.meta-label {
  color: #64748b;
  font-size: 22rpx;
}

.meta-value {
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 24rpx;
  word-break: break-word;
}
