<view class="page">
  <view class="card">
    <view class="title">更多</view>
    <view class="subtle">时刻表、排班、历史和导入</view>
  </view>

  <view class="card identity-card">
    <view class="section-head">
      <view class="section-copy">
        <view class="section-title">内置身份</view>
        <view class="subtle">{{identityLabel}}</view>
      </view>
      <view class="pill {{isDefaultIdentity ? 'pill-gray' : 'pill-primary'}}">
        {{isDefaultIdentity ? '默认' : '已切换'}}
      </view>
    </view>

    <view class="preset-strip">
      <block wx:for="{{presets}}" wx:key="id">
        <button
          class="preset-chip {{item.active ? 'preset-chip-active' : ''}}"
          plain="true"
          data-id="{{item.id}}"
          bindtap="applyPreset"
        >
          <view class="preset-chip-title">{{item.title}}</view>
          <view class="preset-chip-sub">{{item.note}}</view>
        </button>
      </block>
    </view>

    <view class="form-row">
      <view class="field-label">operatorId</view>
      <input class="input" value="{{operatorId}}" data-field="operatorId" bindinput="onIdentityInput" placeholder="op-001" />
    </view>

    <view class="form-row">
      <view class="field-label">operatorName</view>
      <input class="input" value="{{operatorName}}" data-field="operatorName" bindinput="onIdentityInput" placeholder="张三" />
    </view>

    <view class="form-row">
      <view class="field-label">role</view>
      <view class="role-segment">
        <block wx:for="{{roleOptions}}" wx:key="value">
          <button
            class="role-option {{role === item.value ? 'role-option-active' : ''}}"
            plain="true"
            data-role="{{item.value}}"
            bindtap="selectRole"
          >
            {{item.label}}
          </button>
        </block>
      </view>
    </view>

    <view class="button-row identity-actions">
      <button class="btn btn-primary" bindtap="saveIdentity">保存身份</button>
      <button class="btn btn-muted" bindtap="resetIdentity">恢复默认</button>
    </view>
  </view>

  <view class="grid">
    <block wx:for="{{entries}}" wx:key="title">
      <view class="entry-card" data-path="{{item.path}}" bindtap="openEntry">
        <view class="entry-title">{{item.title}}</view>
        <view class="subtle">{{item.note}}</view>
      </view>
    </block>
  </view>
</view>
