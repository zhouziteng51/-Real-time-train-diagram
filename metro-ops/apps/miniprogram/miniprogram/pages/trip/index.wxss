.task-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1px solid #dbe3ef;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.task-header,
.duty-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.task-title-block {
  min-width: 0;
}

.task-title,
.panel-title {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.task-sub,
.panel-sub {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
  word-break: break-word;
}

.progress-track {
  height: 8rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e2e8f0;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #2563eb;
}

.task-times {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  color: #64748b;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 22rpx;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.trip-actions {
  margin-top: 20rpx;
}

.action-btn {
  min-width: 0;
  padding: 18rpx 10rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.action-btn::after {
  border: 0;
}

.btn-primary {
  background: #2563eb;
  color: #ffffff;
}

.btn-muted {
  background: #e2e8f0;
  color: #0f172a;
}

.btn-secondary {
  background: #0f172a;
  color: #ffffff;
}

.btn-hover {
  opacity: 0.88;
}

.btn:disabled {
  opacity: 0.45;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.info-cell {
  flex: 1 1 calc(50% - 7rpx);
  min-width: 0;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.info-cell.wide {
  flex-basis: 100%;
}

.info-label {
  color: #64748b;
  font-size: 22rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-word;
}

.event-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 1px solid #dbe3ef;
  font-size: 24rpx;
}

.event-row:first-of-type {
  border-top: 0;
}

.event-time {
  flex: 0 0 128rpx;
  color: #64748b;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}

.event-main {
  flex: 0 0 160rpx;
  color: #0f172a;
  font-weight: 700;
}

.event-sub {
  flex: 1;
  min-width: 0;
  color: #64748b;
  word-break: break-word;
}
