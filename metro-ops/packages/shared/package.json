{
  "name": "@metro-ops/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state-machines/*": {
      "types": "./dist/state-machines/*.d.ts",
      "default": "./dist/state-machines/*.js"
    },
    "./domain/*": {
      "types": "./dist/domain/*.d.ts",
      "default": "./dist/domain/*.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "default": "./dist/contracts/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
