{
  "name": "metro-ops",
  "version": "0.1.0",
  "private": true,
  "description": "轨道交通乘务与交路管理系统 (Metro Ops Control)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./apps/**\" build",
    "dev:backend": "pnpm --filter @metro-ops/backend dev",
    "dev:frontend": "pnpm --filter @metro-ops/frontend dev",
    "ci": "pnpm lint && pnpm typecheck && pnpm test",
    "ci:restricted": "pnpm lint && pnpm typecheck && pnpm test:automation",
    "daily:local": "node scripts/local-daily-check.mjs",
    "daily:automation": "node scripts/local-daily-check.mjs --restricted-automation",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:automation": "pnpm -r --filter '!@metro-ops/shared' test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.4"
  }
}
